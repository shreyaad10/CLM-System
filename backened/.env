# =============================================
# .env - Environment Variables
# IMPORTANT: Never commit this file to GitHub!
# =============================================

# MongoDB connection string
# For local MongoDB: mongodb://localhost:27017/minicrm
# For MongoDB Atlas (cloud): paste your Atlas connection string here
MONGO_URI=mongodb+srv://minicrm_admin:admin123@crmcluster.tigewma.mongodb.net/?appName=crmcluster
# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Secret key for signing JWT tokens (change this to something random in production)
JWT_SECRET=mini_crm_super_secret_key_2024

# Port for the Express server
PORT=5000
